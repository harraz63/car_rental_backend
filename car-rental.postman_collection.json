{
  "info": {
    "name": "Car Rental System API",
    "description": "Complete API collection for the Car Rental System with Admin Approval Workflow.\n\n📌 HOW TO USE:\n1. Run 'Login as Admin' → adminToken auto-saved\n2. Run 'Signup Owner (with Car)' → ownerToken + carId auto-saved\n3. Run 'Signup User' then 'Login as User' → userToken auto-saved\n4. All subsequent requests use saved tokens & IDs automatically\n\n✅ NEW: DELETE /cars/:id — Admin or Owner",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "ownerToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "carId",
      "value": ""
    },
    {
      "key": "rentalId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Signup User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user + token', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.have.property('user');",
                  "  pm.expect(res.data).to.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/signup-user",
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": \"Ahmed Mohamed\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Signup Owner (with Car) ★",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.status === 'success' && res.data) {",
                  "  if (res.data.token) {",
                  "    pm.collectionVariables.set('ownerToken', res.data.token);",
                  "    console.log('✅ ownerToken saved');",
                  "  }",
                  "  if (res.data.car && res.data.car._id) {",
                  "    pm.collectionVariables.set('carId', res.data.car._id);",
                  "    console.log('✅ carId saved:', res.data.car._id);",
                  "  }",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user + car + token', () => {",
                  "  pm.expect(res.data).to.have.property('user');",
                  "  pm.expect(res.data).to.have.property('car');",
                  "  pm.expect(res.data).to.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/signup-owner",
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": \"Mohamed Owner\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"car\": {\n    \"brand\": \"Toyota\",\n    \"model\": \"Camry\",\n    \"year\": 2022,\n    \"color\": \"White\",\n    \"dailyPrice\": 250,\n    \"location\": \"Cairo\",\n    \"description\": \"Clean and comfortable car\",\n    \"numberOfSeats\": 5,\n    \"engine\": \"2.5L\",\n    \"transmission\": \"automatic\",\n    \"fuelType\": \"petrol\",\n    \"images\": [\n      \"https://image1.com/car.jpg\",\n      \"https://image2.com/car.jpg\"\n    ]\n  }\n}"
            }
          }
        },
